# ─── Database (Neon / Supabase / Railway PostgreSQL) ───────────────────────────
# Neon provides two URLs: `DATABASE_URL` uses connection pooling (PgBouncer),
# `DIRECT_URL` is the direct connection used by Prisma Migrate.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── Redis (Upstash — for idempotency key caching, optional but recommended) ──
UPSTASH_REDIS_REST_URL="https://YOUR-ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# ─── Reservation TTL ────────────────────────────────────────────────────────────
# How many minutes a PENDING reservation is valid before auto-expiry.
RESERVATION_TTL_MINUTES=10

# ─── Cron job protection ────────────────────────────────────────────────────────
# A random secret that protects the /api/cron/expire endpoint from external callers.
# Vercel automatically passes Authorization: Bearer <CRON_SECRET> for cron invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET="your-random-secret-here"

# ─── Next.js public vars (accessible in browser) ───────────────────────────────
NEXT_PUBLIC_RESERVATION_TTL_MINUTES=10
